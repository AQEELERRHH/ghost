{
  "name": "ghost-agent",
  "version": "1.0.0",
  "description": "GHOST — Your On-Chain AI Agent. Build X Hackathon Season 2.",
  "scripts": {
    "compile": "npx hardhat compile",
    "deploy": "npx hardhat run scripts/deploy.js --network xlayer",
