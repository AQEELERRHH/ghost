  "dependencies": {
    "axios": "^1.6.0",
    "dotenv": "^16.0.0",
    "ethers": "^6.9.0",
    "http-server": "^14.1.1"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^4.0.0",
    "@openzeppelin/contracts": "^5.0.0",
    "hardhat": "^2.19.0"
  }
}
